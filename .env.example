# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (PostgreSQL — Railway or Supabase)
DATABASE_URL=postgresql://user:password@host:5432/propra

# Auth (NextAuth v5 / Auth.js)
AUTH_SECRET=                # openssl rand -base64 32
AUTH_URL=http://localhost:3000

# Email provider (Resend — https://resend.com)
RESEND_API_KEY=re_...
AUTH_EMAIL_FROM=Arca <noreply@arca.ai>
# Note: Day-3 and Day-7 nurture emails use Resend scheduledAt (paid plan required)
# On free tier these silently fail — signup flow still works, only nurture is affected
# Resend Pro starts at $20/mo: https://resend.com/pricing

# Admin
ADMIN_EMAIL=hello@arcahq.ai  # User with this email is auto-granted isAdmin on first sign-in

# Build
NIXPACKS_NO_CACHE=1
