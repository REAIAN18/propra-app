# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: set to your custom domain, e.g. https://realhq.ai
# NEXT_PUBLIC_ vars are baked into the build — must be set BEFORE Railway builds

# Database (PostgreSQL — Supabase)
DATABASE_URL=postgresql://user:password@host:6543/postgres?pgbouncer=true
# Supabase pooler connection (port 6543) — used for app queries
# Project: okyqtkmfxuyjilmxgrcy.supabase.co

DIRECT_URL=postgresql://user:password@host:5432/postgres
# Supabase direct connection (port 5432) — used only for migrations (prisma migrate deploy)
# IMPORTANT: Use pooler (6543) for app, direct (5432) for migrations only

# Auth (NextAuth v5 / Auth.js)
AUTH_SECRET=                # openssl rand -base64 32
AUTH_URL=http://localhost:3000
# Production: must match your custom domain exactly — no trailing slash
# Example: AUTH_URL=https://realhq.ai
# If AUTH_URL doesn't match the domain users access the site from, magic links will redirect to wrong URL

# Email provider (Resend — https://resend.com)
RESEND_API_KEY=re_...
AUTH_EMAIL_FROM=RealHQ <noreply@realhq.ai>
OUTREACH_EMAIL_FROM=Ian Baron <ian@realhq.ai>
# Resend free tier is sufficient — nurture emails use DB queue (not Resend scheduledAt)
# The /api/cron/send-emails endpoint flushes queued emails; wire a cron-job.org job to call it every 30 min
RESEND_WEBHOOK_SECRET=whsec_...  # Generate in Resend dashboard → Webhooks; point to /api/webhooks/resend

# Cron security — protects /api/cron/send-emails
CRON_SECRET=                # openssl rand -hex 32 — set same value on cron-job.org

# AI
ANTHROPIC_API_KEY=sk-ant-...
# Required for /api/ask (portfolio AI chat) and /api/documents/parse-policy (insurance PDF upload).
# Without it, ask returns 500 and parse-policy returns { ok: false, error: "PDF parsing not configured" }.

# Admin
ADMIN_EMAIL=hello@realhq.ai
# User with this email is auto-granted isAdmin on first sign-in

# FRED API (macroeconomic rates — https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=                # Free — register at fred.stlouisfed.org to get a key
# Powers /api/cron/sofr — fetches daily SOFR rate (Secured Overnight Financing Rate)
# Wire a daily cron to GET /api/cron/sofr with Authorization: Bearer <CRON_SECRET>

# EIA API (U.S. Energy Information Administration — https://www.eia.gov/opendata/register.php)
EIA_API_KEY=                 # Free — register at eia.gov/opendata to get a key (instant)
# Powers /api/cron/energy-rates — fetches FL commercial electricity rate monthly
# Wire a daily cron to GET /api/cron/energy-rates with Authorization: Bearer <CRON_SECRET>
# Also auto-fetches on first energy-summary request if DB has no cached rate

# ATTOM Data API (US county assessor data — https://api.developer.attomdata.com/)
ATTOM_API_KEY=                 # Paid — register at developer.attomdata.com; powers /api/property/lookup assessor panel
# Powers county assessor lookup: sale history, assessed value, building class, lot size, year built
# Without this key, the add-property confirmation screen shows pending-data badges for assessor fields

# AWS Textract (document text extraction — https://aws.amazon.com/textract/)
AWS_ACCESS_KEY_ID=             # IAM user with textract:DetectDocumentText permission
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1           # Default: us-east-1
# Without these, the upload pipeline falls back to Claude native PDF parsing (no Textract step)

# Redis (BullMQ async document ingestion queue)
REDIS_URL=                     # e.g. redis://default:password@host:6379
# Optional — Railway Redis add-on. Without this, document ingestion runs synchronously.
# When set, upload endpoint enqueues jobs; run `node dist/workers/document-ingest.js` as a separate worker.

# LoopNet RapidAPI (Deal Scout — https://rapidapi.com/loopnet-api/api/loopnet-api)
X_RapidAPI_Key=               # Subscribe to loopnet-api on RapidAPI; paste the key here
# Powers /api/scout/deals — fetches active commercial listings for the user's market
# Without this key, Deal Scout returns no listings and shows "Market data temporarily unavailable"

# Build
NIXPACKS_NO_CACHE=1
