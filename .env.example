# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Production: set to your custom domain, e.g. https://realhq.ai
# NEXT_PUBLIC_ vars are baked into the build — must be set BEFORE Railway builds

# Database (PostgreSQL — Railway add-on or Supabase)
DATABASE_URL=postgresql://user:password@host:5432/propra
# Railway auto-populates this when you add a Postgres service

# Auth (NextAuth v5 / Auth.js)
AUTH_SECRET=                # openssl rand -base64 32
AUTH_URL=http://localhost:3000
# Production: must match your custom domain exactly — no trailing slash
# Example: AUTH_URL=https://realhq.ai
# If AUTH_URL doesn't match the domain users access the site from, magic links will redirect to wrong URL

# Email provider (Resend — https://resend.com)
RESEND_API_KEY=re_...
AUTH_EMAIL_FROM=RealHQ <noreply@realhq.ai>
OUTREACH_EMAIL_FROM=Ian Baron <ian@realhq.ai>
# Resend free tier is sufficient — nurture emails use DB queue (not Resend scheduledAt)
# The /api/cron/send-emails endpoint flushes queued emails; wire a cron-job.org job to call it every 30 min
RESEND_WEBHOOK_SECRET=whsec_...  # Generate in Resend dashboard → Webhooks; point to /api/webhooks/resend

# Cron security — protects /api/cron/send-emails
CRON_SECRET=                # openssl rand -hex 32 — set same value on cron-job.org

# AI
ANTHROPIC_API_KEY=sk-ant-...
# Required for /api/ask (portfolio AI chat) and /api/documents/parse-policy (insurance PDF upload).
# Without it, ask returns 500 and parse-policy returns { ok: false, error: "PDF parsing not configured" }.

# Admin
ADMIN_EMAIL=hello@realhq.ai
# User with this email is auto-granted isAdmin on first sign-in

# FRED API (macroeconomic rates — https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=                # Free — register at fred.stlouisfed.org to get a key
# Powers /api/cron/sofr — fetches daily SOFR rate (Secured Overnight Financing Rate)
# Wire a daily cron to GET /api/cron/sofr with Authorization: Bearer <CRON_SECRET>

# Build
NIXPACKS_NO_CACHE=1
