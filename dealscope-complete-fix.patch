+import { calculateIRR } from './irr';
+
+export type VerdictType = 'STRONG_BUY' | 'CONDITIONAL' | 'REJECT';
+
+export interface VerdictResult {
+  verdict: VerdictType;
+  targetPrice: number;
+  reasoning: string;
+}
+
+export function calculateVerdict(property: any): VerdictResult {
+  const irrResult = calculateIRR(property);
+  const irr = irrResult.irr;
+  const askingPrice = property.askingPrice || 0;
+
+  if (irr >= 0.15) {
+    return {
+      verdict: 'STRONG_BUY',
+      targetPrice: askingPrice,
+      reasoning: `Strong IRR of ${(irr * 100).toFixed(1)}%. Proceed at asking price.`
+    };
+  }
+
+  if (irr >= 0.10) {
+    return {
+      verdict: 'STRONG_BUY',
+      targetPrice: askingPrice,
+      reasoning: `Good IRR of ${(irr * 100).toFixed(1)}%. Acceptable at asking price.`
+    };
+  }
+
+  const targetIRR = 0.10;
+  const irrGap = targetIRR - irr;
+  const priceReduction = irrGap * askingPrice * 10;
+  const targetPrice = Math.max(askingPrice - priceReduction, askingPrice * 0.75);
+
+  return {
+    verdict: 'CONDITIONAL',
+    targetPrice: targetPrice,
+    reasoning: `IRR of ${(irr * 100).toFixed(1)}% is below target. Negotiate to £${Math.round(targetPrice / 1000000)}m for 10% IRR.`
+  };
+}
