@@ -0,0 +1,67 @@
+export interface CashFlow {
+  year: number;
+  amount: number;
+  description: string;
+}
+
+export interface IRRResult {
+  irr: number;
+  cashFlows: CashFlow[];
+  confidence: 'LOW' | 'MEDIUM' | 'HIGH';
+}
+
+export function calculateIRR(property: any): IRRResult {
+  const purchasePrice = property.askingPrice || 0;
+  const sdlt = calculateSDLT(purchasePrice);
+  const totalCostIn = purchasePrice + sdlt + 15000 + 8000;
+
+  const voidMonths = property.expectedVoid || 14;
+  const businessRatesMonthly = (property.businessRates || 0) / 12;
+  const totalVoidCost = businessRatesMonthly * voidMonths + (2000 + 800 + 1500) * voidMonths;
+
+  const erv = property.erv || (property.size || 0) * 28;
+  const totalLettingCost = erv * 0.15 + 5000 + (erv / 12) * 12 + (property.size || 0) * 5;
+
+  const cashFlows: CashFlow[] = [
+    { year: 0, amount: -totalCostIn, description: 'Acquisition' },
+    { year: 1, amount: -(totalVoidCost + totalLettingCost), description: 'Void + letting' }
+  ];
+
+  const noi = erv - erv * 0.15;
+  for (let year = 2; year <= 10; year++) {
+    cashFlows.push({ year, amount: noi, description: `Year ${year} NOI` });
+  }
+
+  const exitValue = noi / 0.08;
+  const exitProceeds = exitValue - exitValue * 0.015 - 10000;
+  cashFlows[cashFlows.length - 1].amount += exitProceeds;
+
+  const irr = solveIRR(cashFlows.map(cf => cf.amount));
+  const confidence = property.passingRent > 0 ? 'HIGH' : 'MEDIUM';
+
+  return { irr, cashFlows, confidence };
+}
+
+function solveIRR(cashFlows: number[]): number {
+  let rate = 0.1;
+  for (let i = 0; i < 1000; i++) {
+    let npv = 0, dnpv = 0;
+    for (let t = 0; t < cashFlows.length; t++) {
+      npv += cashFlows[t] / Math.pow(1 + rate, t);
+      dnpv -= t * cashFlows[t] / Math.pow(1 + rate, t + 1);
+    }
+    if (Math.abs(npv) < 0.00001) return rate;
+    if (dnpv === 0) return rate;
+    const newRate = rate - npv / dnpv;
+    if (newRate < -0.99) rate = -0.99;
+    else if (newRate > 10) rate = 10;
+    else rate = newRate;
+  }
+  return rate;
+}
+
+function calculateSDLT(price: number): number {
+  if (price <= 150000) return 0;
+  if (price <= 250000) return (price - 150000) * 0.02;
+  return 2000 + (price - 250000) * 0.05;
+}
