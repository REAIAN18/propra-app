generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  // In Prisma 7, connection URLs are configured in prisma.config.ts
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // RealHQ-specific fields
  portfolio     Portfolio @default(FL_MIXED)
  isAdmin       Boolean   @default(false)
  onboardedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  documents        Document[]
  userAssets       UserAsset[]
  insuranceQuotes  InsuranceQuote[]
  energyQuotes     EnergyQuote[]
  commissions      Commission[]
  acquisitions     Acquisition[]
  workOrders               WorkOrder[]
  incomeActivations        IncomeActivation[]
  tenantEngagementActions  TenantEngagementAction[]
  scoutReactions           ScoutReaction[]
  tenants                  Tenant[]
  leases                   Lease[]
  tenantPayments           TenantPayment[]
  tenantEngagements        TenantEngagement[]
  scoutUnderwritings       ScoutUnderwriting[]
  scoutLois                ScoutLOI[]
  holdSellScenarios        HoldSellScenario[]
  rentReviewEvents         RentReviewEvent[]
  assetValuations          AssetValuation[]
  planningApplications     PlanningApplication[]
  sellEnquiries            SellEnquiry[]
  energyReads              EnergyRead[]
  energyAnomalies          EnergyAnomaly[]
  solarAssessments         SolarAssessment[]
  solarQuoteRequests       SolarQuoteRequest[]
  lettings                 Letting[]
  complianceCertificates   ComplianceCertificate[]
  monthlyFinancials        MonthlyFinancial[]
  loans                    Loan[]
  lenderRelationships      LenderRelationship[]
  transactionRooms         TransactionRoom[]
  acquisitionStrategies    AcquisitionStrategy[]
  emailTrackings           EmailTracking[]
  dealFinanceModels        DealFinanceModel[]
  investorContacts         InvestorContact[]
  investorOutreach         InvestorOutreach[]
  vendorApproaches         VendorApproach[]
  approachLetters          ApproachLetter[]
  userPipelines            UserPipeline[]
  savedSearches            SavedSearch[]
  alertEvents              AlertEvent[]
  propertyWatchlist        PropertyWatchlist[]
  portfolioProperties      PortfolioProperty[]
  creditBalance            CreditBalance?
  creditTransactions       CreditTransaction[]
  financialBudgets         FinancialBudget[]
}

enum Portfolio {
  FL_MIXED
  SE_LOGISTICS
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model SignupLead {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  phone          String?
  company        String?
  assetCount     Int?
  portfolioValue String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Unsubscribe {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ScheduledEmail {
  id           String    @id @default(cuid())
  to           String
  from         String
  subject      String
  html         String    @db.Text
  text         String    @db.Text
  sendAfter    DateTime
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  prospectKey  String?
  touchNumber  Int?
  market       String?

  @@index([sendAfter, sentAt])
}

model AuditLead {
  id              String   @id @default(cuid())
  email           String
  portfolioInput  String
  assetType       String?
  assetCount      Int?
  estimateTotal   Int?
  estimateJson    String?
  enrichmentsJson String?  @db.Text
  createdAt       DateTime @default(now())
}


model Document {
  id            String   @id @default(cuid())
  userId        String?
  filename      String
  fileSize      Int
  mimeType      String
  documentType  String?
  summary       String?
  extractedData Json?
  extractedJson String?  @db.Text
  status        String   @default("pending")
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user                   User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAssets             UserAsset[]
  extracts               DocumentExtract[]
  complianceCertificates ComplianceCertificate[]
}

model DocumentExtract {
  id             String   @id @default(cuid())
  documentId     String
  type           String   // "insurance" | "energy" | "lease" | "other"
  rawText        String?  @db.Text
  structuredJson Json?
  confidence     Float?
  extractedAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ProspectStatus {
  id              String   @id @default(cuid())
  prospectKey     String   @unique
  status          String
  notes           String?  @db.Text
  linkedinSent    Boolean  @default(false)
  emailSent       Boolean  @default(false)
  touch1SentAt    String?
  touch2SentAt    String?
  touch3SentAt    String?
  emailOpened     Boolean  @default(false)
  emailClicked    Boolean  @default(false)
  emailBounced    Boolean  @default(false)
  lastContact     String?
  emailOverride    String?
  linkedinOverride String?
  manualStatus     String?
  manualNote       String?  @db.Text
  manualUpdatedAt  DateTime?
  updatedAt        DateTime @updatedAt
  updatedBy        String?
}

model UserAsset {
  id               String    @id @default(cuid())
  userId           String
  name             String
  assetType        String
  location         String
  sqft             Int?
  grossIncome      Int?
  netIncome        Int?
  passingRent      Float?
  marketERV        Float?
  insurancePremium Int?
  marketInsurance  Int?
  energyCost       Int?
  marketEnergyCost Int?
  occupancy        Float?
  sourceDocumentId String?
  // Property detail fields (PRO-251)
  address          String?
  postcode         String?
  country          String?   @default("UK")
  latitude         Float?
  longitude        Float?
  epcRating        String?
  epcFetched       Boolean   @default(false)
  formattedAddress String?
  epcExpiry        DateTime?
  floodRisk        String?
  floodZone        String?
  femaZoneRaw      Json?
  planningHistory  Json?
  satelliteUrl     String?
  marketCapRate    Float?
  marketRentSqft   Float?
  // Wave 2 fields
  meterType            String?   // "hh" | "sme"
  planningImpactSignal String?   // "positive" | "neutral" | "negative"
  planningLastFetched  DateTime?
  avmValue             Float?
  avmLow               Float?
  avmHigh              Float?
  avmDate              DateTime?
  avmConfidence        Float?
  pipelineStage        String?
  pipelineUpdatedAt    DateTime?
  brochureDocId        String?
  tenantCount          Int?
  wault                Float?
  region               String?   // "se_uk" | "fl_us"
  // Insurance risk scorecard (Wave 2 — PRO-610)
  insuranceRiskScore      Float?
  insuranceRiskFactors    Json?
  insuranceRoadmap        Json?
  insuranceRiskAssessedAt DateTime?
  // Development potential (Wave 2 — PRO-604)
  siteCoveragePct        Float?
  pdRights               String?
  pdRightsDetail         String?   @db.Text
  changeOfUsePotential   String?
  changeOfUseDetail      String?   @db.Text
  airRightsPotential     String?
  airRightsDetail        String?   @db.Text
  devPotentialAssessedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceDocument    Document?         @relation(fields: [sourceDocumentId], references: [id])
  insuranceQuotes   InsuranceQuote[]
  energyQuotes      EnergyQuote[]
  commissions       Commission[]
  comparables          PropertyComparable[]
  valuations           AssetValuation[]
  planningApplications PlanningApplication[]
  workOrders           WorkOrder[]
  incomeActivations    IncomeActivation[]
  tenants              Tenant[]
  leases               Lease[]
  holdSellScenario     HoldSellScenario?
  rentReviewEvents     RentReviewEvent[]
  sellEnquiries        SellEnquiry[]
  energyReads          EnergyRead[]
  energyAnomalies      EnergyAnomaly[]
  solarAssessment      SolarAssessment?
  solarQuoteRequests   SolarQuoteRequest[]
  lettings             Letting[]
  complianceCertificates ComplianceCertificate[]
  monthlyFinancials    MonthlyFinancial[]
  loans                Loan[]
  transactionRooms     TransactionRoom[]

  @@unique([userId, name])
}

model PropertyComparable {
  id           String   @id @default(cuid())
  assetId      String
  attomId      String?
  address      String
  sqft         Int?
  yearBuilt    Int?
  saleAmount   Float?
  saleDate     String?  // YYYY-MM-DD
  pricePerSqft Float?
  source       String   @default("attom")
  fetchedAt    DateTime @default(now())

  asset        UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@unique([assetId, source, address])
}

model InsuranceQuote {
  id               String   @id @default(cuid())
  userId           String
  assetId          String?
  carrier          String
  quoteRef         String?
  policyType       String?
  currentPremium   Float?
  quotedPremium    Float
  annualSaving     Float?
  coverageDetails  Json?
  dataSource       String   @default("benchmark") // "benchmark" | "live_api"
  status           String   @default("pending")   // "pending" | "bound" | "declined" | "expired"
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model EnergyQuote {
  id              String   @id @default(cuid())
  userId          String
  assetId         String?
  supplier        String
  currentSupplier String?
  currentRate     Float?
  quotedRate      Float
  annualUsage     Float?
  currentCost     Float?
  quotedCost      Float
  annualSaving    Float?
  dataSource      String   @default("benchmark") // "benchmark" | "live_api"
  status          String   @default("pending")   // "pending" | "switched" | "declined" | "expired"
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset  UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model Commission {
  id              String   @id @default(cuid())
  userId          String
  assetId         String?
  category        String   // "insurance" | "energy" | "rent" | "ancillary"
  sourceId        String?  // FK to InsuranceQuote.id or EnergyQuote.id
  annualSaving    Float
  commissionRate  Float    @default(0.15)
  commissionValue Float
  status          String   @default("pending") // "pending" | "confirmed" | "invoiced" | "paid"
  placedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model ClientPortfolio {
  id        String   @id @default(cuid())
  name      String   // "Starlight Industrial Holdings"
  urlKey    String   @unique // "starlight-industrial"
  data      Json     // serialized Portfolio type
  createdBy String?  // admin email
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MacroRate {
  id        String   @id @default(cuid())
  series    String   // e.g. "SOFR"
  value     Float    // rate in percent, e.g. 5.30
  date      String   // YYYY-MM-DD as reported by FRED
  fetchedAt DateTime @default(now())

  @@unique([series, date])
}

model Acquisition {
  id            String   @id @default(cuid())
  userId        String
  name          String
  location      String
  assetType     String   // "industrial" | "warehouse" | "office" | "retail" | "flex" | "mixed"
  sqft          Int?
  askingPrice   Float
  estimatedYield Float
  marketYield   Float?
  score         Int?     // 0–100 fit score
  status        String   @default("screening") // "screening" | "loi" | "due_diligence" | "exchange" | "passed"
  rationale     String?  @db.Text
  noi           Float?
  currency      String   @default("USD") // "USD" | "GBP"
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AcquisitionStrategy {
  id              String   @id @default(cuid())
  userId          String
  name            String?  // Optional name like "FL Industrial" or "SE Logistics"
  targetTypes     String[] // ["industrial", "warehouse", "office", "retail", "flex", "mixed"]
  targetGeography String[] // ["FL", "SE_UK", "London", "Tampa"] — free-form for flexibility
  minYield        Float?   // e.g., 6.0 for 6%
  maxYield        Float?   // e.g., 10.0 for 10%
  minPrice        Float?   // e.g., 1000000
  maxPrice        Float?   // e.g., 12000000
  minSqft         Int?     // e.g., 5000
  maxSqft         Int?     // e.g., 50000
  currency        String   @default("USD") // "USD" | "GBP"
  isActive        Boolean  @default(true)
  // DealScope-specific fields
  signalTypes     String[] @default(["administration", "auction", "mees", "absent_owner", "dissolved", "probate"]) // Signals user cares about
  alertFrequency  String   @default("daily") // "realtime" | "daily" | "weekly"
  notificationChannels String[] @default(["inapp"]) // ["inapp", "email", "push"]
  riskAppetite    String?  // "conservative" | "moderate" | "aggressive"
  maxLeaseLength  Int?     // Minimum acceptable lease years
  avoidedSignals  String[] @default([]) // Signals user never wants to see
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model IncomeActivation {
  id               String   @id @default(cuid())
  userId           String
  assetId          String?
  opportunityType  String   // "ev_charging" | "solar" | "telecom" | "parking" | "billboard" | "vending" | "roofspace" | "coworking" | "storage" | "laundry" | "naming_rights" | "custom"
  opportunityLabel String?
  annualIncome     Float?
  status           String   @default("requested") // Legacy: "requested" | "in_progress" | "live" | "declined"
  requestedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // V2: Activation stages (PRO-774)
  activationStage  String?  @default("identified") // "identified" | "researching" | "quoting" | "approved" | "installing" | "live" | "renewing"
  stageHistory     Json?    // [{ stage: "identified", date: "2026-03-29", notes: "..." }, ...]

  // V2: Provider & contract tracking
  providerContact  String?  // Provider name + contact
  quotesReceived   Json?    // [{ provider: "ChargePoint", amount: 24600, date: "2026-03-15", accepted: true }, ...]

  // Live tracking fields (PRO-755)
  contractStart    DateTime?
  contractEnd      DateTime?
  escalationPct    Float?   // annual escalation percentage (e.g. 3.0 for 3%)
  monthlyActuals   Json?    // [{ month: "2026-01", amount: 2100 }, ...]
  renewalAlertSent Boolean  @default(false)

  // V2: Learning loop & custom opportunities
  dismissReason    String?  // "not_suitable" | "no_demand" | "planning_restrictions" | "tenant_objection" | "capex_too_high"
  isCustom         Boolean  @default(false) // User-added vs AI-discovered

  // V2: Opportunity detail & evidence
  confidence       Float?   // 0-1 confidence score based on evidence
  methodology      String?  @db.Text // How the amount was calculated
  comparables      Json?    // [{ address: "...", income: 24000, distance: 1.2 }, ...]
  riskFactors      Json?    // [{ factor: "planning_permission", severity: "medium" }, ...]

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model WorkOrder {
  id               String   @id @default(cuid())
  userId           String
  assetId          String?
  tenderType       String?  // "MAINTENANCE" | "COMPLIANCE" | "CAPITAL_WORKS" | "CONSTRUCTION" | "GREEN_ESG" | "PROFESSIONAL"
  jobType          String   // specific job e.g. "HVAC Service"
  description      String   @db.Text
  scopeOfWorks     String?  @db.Text  // RealHQ-structured formal brief
  accessNotes      String?
  timing           String?
  targetStart      String?  // YYYY-MM-DD
  budgetEstimate   Float?
  benchmarkLow     Float?
  benchmarkHigh    Float?
  benchmarkSource  String?
  capRateValueAdd  Float?   // asset value uplift for capital works (£/$)
  status           String   @default("draft")
  // draft | tendered | quotes_received | awarded | in_progress | complete
  contractor       String?
  costEstimate     Float?
  currency         String   @default("GBP")
  autoTriggerFrom  String?  // "compliance" | "energy" | "income" | "planning"
  autoTriggerRef   String?
  agreedPrice      Float?   // price agreed after bid selection
  contractorId     String?  // winning contractor FK (soft link to Contractor.id)
  finalCost        Float?   // actual final cost on completion
  aiScopeJson      Json?    // structured scope from POST /scope: { scopeSummary, lineItems, totalEstimate, tradeRequired, urgency }
  // V2 fields
  priority         String?  // "urgent" | "high" | "normal" | "low"
  beforePhotos     Json?    // [{url, caption, takenAt}]
  afterPhotos      Json?    // [{url, caption, takenAt}]
  variationOrders  Json?    // [{description, amount, approved, date}]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset      UserAsset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  quotes     TenderQuote[]
  milestones WorkOrderMilestone[]
  completion WorkOrderCompletion?
}

model TenderQuote {
  id             String    @id @default(cuid())
  workOrderId    String
  contractorName String
  price          Float
  warranty       String?   // e.g. "12 months"
  timeline       String?   // e.g. "2 weeks"
  rating         Float?    // e.g. 4.8
  notes          String?   @db.Text
  awarded        Boolean   @default(false)
  tenderToken    String?   @unique  // PRO-567: token-auth tender response URL
  contractorId   String?            // FK reference to Contractor.id (soft link)
  // V2 fields
  breakdown      Json?              // {labour, materials, plant, overheads, margin}
  proposedStart  DateTime?
  proposedDuration Int?             // days
  paymentTerms   String?
  questions      Json?              // Q&A from contractor
  status         String    @default("draft") // "draft" | "submitted"
  submittedAt    DateTime?
  createdAt      DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model TenantEngagementAction {
  id          String   @id @default(cuid())
  userId      String
  leaseRef    String   // synthetic lease ID from lease-summary (doc.id or docId-N)
  actionType  String   // "engage_renewal" | "relet" | "review_break"
  status      String   @default("requested") // "requested" | "completed"
  requestedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, leaseRef])
}

// ── Scout feed ────────────────────────────────────────────────────────
model ScoutDeal {
  id                     String   @id @default(cuid())
  externalId             String?  @unique // LoopNet listing ID or similar for dedup
  address                String
  assetType              String   // "industrial" | "warehouse" | "office" | "retail" | "flex" | "mixed"
  sqft                   Int?
  askingPrice            Float?
  guidePrice             Float?
  capRate                Float?   // cap rate percentage e.g. 6.5
  brokerName             String?  // listing broker/agent name
  daysOnMarket           Int?
  sourceTag              String   // "Auction" | "Pre-market" | "Planning signal" | "Distressed" | "LoopNet"
  sourceUrl              String?
  hasLisPendens          Boolean  @default(false)
  hasInsolvency          Boolean  @default(false)
  lastSaleYear           Int?
  hasPlanningApplication Boolean  @default(false)
  solarIncomeEstimate    Float?   // annual £
  inFloodZone            Boolean  @default(false)
  auctionDate            DateTime?
  ownerName              String?
  satelliteImageUrl      String?
  signalCount            Int      @default(0) // 0-5 for intelligence dots
  currency               String   @default("GBP")
  status                 String   @default("active") // "active" | "removed"
  // Wave 2 fields
  pipelineStage          String?
  pipelineUpdatedAt      DateTime?
  brochureDocId          String?
  region                 String?  // "se_uk" | "fl_us"
  // DealScope fields
  epcRating              String?
  yearBuilt              Int?
  buildingSizeSqft       Int?
  tenure                 String?  // "Freehold" | "Leasehold" | "Unknown"
  ownerCompanyId         String?
  currentRentPsf         Float?
  marketRentPsf          Float?
  occupancyPct           Float?
  leaseLengthYears       Float?
  breakDates             Json?    // array of dates
  tenantCompanyId        String?
  tenantCovenantStrength String?  // "strong" | "satisfactory" | "weak"
  dataSources            Json?    // array of source tags
  enrichedAt             DateTime?
  userId                 String?
  analyzedAt             DateTime?
  inputMethod            String?  // "loopnet" | "manual" | "upload" | "api"
  inputRaw               Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  reactions        ScoutReaction[]
  underwriting     ScoutUnderwriting?
  lois             ScoutLOI[]
  comparables      ScoutComparable[]
  financeModel     DealFinanceModel?
  investorOutreach InvestorOutreach[]
  transactionRoom  TransactionRoom?
  vendorApproaches VendorApproach[]
  approachLetters  ApproachLetter[]
  watchlist        PropertyWatchlist[]
  alerts           AlertEvent[]
  pipelines        UserPipeline[]
}

model ScoutReaction {
  id        String   @id @default(cuid())
  userId    String
  dealId    String
  reaction  String   // "interested" | "passed"
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
  @@index([userId])
}

// ─── WAVE 2: WORK ORDERS ────────────────────────────────────────────────────

model Contractor {
  id        String   @id @default(cuid())
  name      String
  region    String   // "se_uk" | "fl_us"
  trades    String[] // ["HVAC", "Electrical", "Roofing", ...]
  email     String
  phone     String?
  rating    Float    @default(4.0)
  jobCount  Int      @default(0)
  verified  Boolean  @default(false)
  // V2 fields
  ratings      Json?    // [{workOrderId, quality, timeliness, communication, value, overall, comment, ratedAt}]
  avgRating    Float?
  completedJobs Int     @default(0)
  insurance    String?  // e.g. "£5M public liability exp 2027-06-30"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([region])
}

model WorkOrderMilestone {
  id          String    @id @default(cuid())
  workOrderId String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      String    @default("pending") // "pending" | "in_progress" | "complete"
  // V2 fields
  paymentAmount     Float?
  paymentReleased   Boolean   @default(false)
  paymentReleasedAt DateTime?
  progressPhotos    Json?     // [{url, caption, takenAt}]
  signOffNotes      String?
  createdAt   DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

model WorkOrderCompletion {
  id                    String   @id @default(cuid())
  workOrderId           String   @unique
  contractorId          String?
  finalCost             Float
  completionNotes       String?  @db.Text
  contractorRatingGiven Float?
  goCardlessPaymentId   String?
  completedAt           DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

// ─── WAVE 2: TENANT INTELLIGENCE ────────────────────────────────────────────

model Tenant {
  id                String    @id @default(cuid())
  userId            String
  assetId           String?
  name              String
  companyNumber     String?
  covenantGrade     String?   // "strong" | "satisfactory" | "weak" | "unknown"
  covenantScore     Float?
  covenantCheckedAt DateTime?
  sector            String?
  email             String?
  arrearsBalance    Float?    @default(0)
  arrearsEscalation String?   @default("none") // "none" | "reminder" | "formal_demand" | "solicitor"
  lastPaymentDate   DateTime?
  paymentTrend      String?   // "improving" | "stable" | "deteriorating"
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user        User          @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset       UserAsset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  leases      Lease[]
  payments    TenantPayment[]
  engagements TenantEngagement[]

  @@unique([userId, name])
  @@index([userId])
}

model Lease {
  id                     String    @id @default(cuid())
  userId                 String
  tenantId               String
  assetId                String
  documentId             String?
  leaseRef               String?
  sqft                   Int       @default(0)
  passingRent            Float     @default(0)
  rentPerSqft            Float?
  startDate              DateTime?
  expiryDate             DateTime?
  breakDate              DateTime?
  reviewDate             DateTime?
  currency               String?
  status                 String    @default("active") // "active" | "expiring_soon" | "expired" | "vacant"
  abstractData           Json?     // Structured lease terms: {rent, reviewType, reviewDates, breakDates, alienation, repairObligation, serviceChargeCap, insuranceObligation, permittedUse, rentDepositAmount}
  abstractSource         String?   // "extracted" | "manual"
  abstractCompleteness   Float?    // 0-1, % of fields populated
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user        User          @relation(fields: [userId],   references: [id], onDelete: Cascade)
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset       UserAsset     @relation(fields: [assetId],  references: [id], onDelete: Cascade)
  payments    TenantPayment[]
  engagements TenantEngagement[]
  rentReviews RentReviewEvent[]

  @@index([userId])
  @@index([tenantId])
  @@index([assetId])
}

model TenantPayment {
  id          String    @id @default(cuid())
  tenantId    String
  leaseId     String
  userId      String
  amount      Float
  dueDate     DateTime
  paidDate    DateTime?
  periodStart DateTime
  status      String    @default("pending") // "pending" | "paid" | "late" | "missed"
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease  Lease  @relation(fields: [leaseId],  references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([tenantId])
}

model TenantEngagement {
  id          String    @id @default(cuid())
  tenantId    String
  leaseId     String
  userId      String
  actionType  String    // "engage_renewal" | "serve_review" | "send_letter"
  letterDraft String?   @db.Text
  emailSentAt DateTime?
  status      String    @default("draft") // "draft" | "sent" | "responded" | "complete"
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease  Lease  @relation(fields: [leaseId],  references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)

  @@index([leaseId])
}

model TenantLetter {
  id          String    @id @default(cuid())
  leaseId     String
  tenantId    String
  userId      String
  assetId     String?
  type        String    // "rent_review" | "renewal" | "re_gear" | "break_notice"
  body        String    @db.Text
  status      String    @default("draft") // "draft" | "sent"
  sentAt      DateTime?
  sentToEmail String?
  createdAt   DateTime  @default(now())

  @@index([leaseId])
  @@index([tenantId])
}

// ─── WAVE 2: SCOUT UNDERWRITING ─────────────────────────────────────────────

model ScoutUnderwriting {
  id            String   @id @default(cuid())
  dealId        String   @unique
  userId        String
  passedRentPa  Float?
  vacancyRate   Float?
  opexPct       Float?
  capexEstimate Float?
  noiGross      Float?
  noinet        Float?
  capRate       Float?
  marketCapRate Float?
  capRateGap    Float?
  yieldOnCost   Float?
  grossYield    Float?
  dscr          Float?
  irr5yr        Float?
  // DealScope fields
  conditionVsMarketGuess        String?  // "superior" | "average" | "inferior"
  yieldBase                     Float?
  yieldTenantAdjustment         Float?
  yieldLeaseAdjustment          Float?
  yieldOverUnderRentAdjustment  Float?
  finalYield                    Float?
  reversionValue                Float?
  userYieldOverrides            Json?    // {base?, tenant?, lease?, rent?}
  scenarioType                  String?  // "base" | "bear" | "bull"
  dataSource    String   @default("estimated")
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoutLOI {
  id                String   @id @default(cuid())
  dealId            String
  userId            String
  offerPrice        Float
  depositPct        Float    @default(0.10)
  conditionalDays   Int      @default(28)
  completionDays    Int      @default(90)
  specialConditions String?  @db.Text
  body              String   @db.Text
  status            String   @default("draft") // "draft" | "sent" | "accepted" | "withdrawn"
  createdAt         DateTime @default(now())

  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dealId, userId])
}

model VendorApproach {
  id           String    @id @default(cuid())
  userId       String
  dealId       String
  message      String?   @db.Text  // Optional message from buyer
  status       String    @default("pending") // "pending" | "viewed" | "interested" | "accepted" | "declined"
  vendorEmail  String?   // Vendor/broker email from deal
  vendorName   String?   // Vendor/broker name from deal
  sentAt       DateTime  @default(now())
  viewedAt     DateTime?
  respondedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dealId])
  @@index([status])
}

// ─── WAVE 2: HOLD VS SELL ────────────────────────────────────────────────────

model HoldSellScenario {
  id                  String   @id @default(cuid())
  assetId             String   @unique
  userId              String
  // Hold scenario outputs
  holdNPV             Float?
  holdIRR             Float?
  holdEquityMultiple  Float?
  holdCashYield       Float?
  // Sell scenario outputs
  estimatedSalePrice  Float?
  sellNetProceeds     Float?
  sellRedeployedNPV   Float?
  sellIRR             Float?
  sellEquityMultiple  Float?
  // Summary
  recommendation      String?  // "strong_hold" | "hold" | "sell" | "needs_review"
  rationale           String?  @db.Text
  confidenceScore     Float?
  dataSource          String?  // "avm" | "estimated"
  // User assumptions (stored for next recalc)
  holdPeriodYears     Float?
  rentGrowthPct       Float?
  exitYield           Float?
  vacancyAllowance    Float?
  capexSchedule       Float?
  sellingCostsPct     Float?
  redeploymentYield   Float?
  lastCalculatedAt    DateTime?
  // v2 fields
  taxEstimate         Json?     // {jurisdiction, acquisitionCost, currentValue, estimatedGain, taxRate, estimatedTax, exchange1031Eligible, deferralAmount}
  dataSourceMap       Json?     // {value: "avm"|"user", rent: "lease"|"user", capRate: "market"|"user"}
  marketTiming        Json?     // {capRateTrend, rateEnvironment, avgDOM, supplyLevel, signal}
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
}

// ─── WAVE 2: RENT REVIEW AUTOMATION ─────────────────────────────────────────

model RentReviewEvent {
  id                  String    @id @default(cuid())
  userId              String
  assetId             String?
  leaseId             String?
  tenantName          String
  propertyAddress     String?
  expiryDate          DateTime
  breakDate           DateTime?
  passingRent         Float
  sqft                Int?
  ervLive             Float?
  ervSource           String?   // "costar" | "attom" | "msci" | "manual"
  ervFetchedAt        DateTime?
  gap                 Float?    // annual uplift at ERV
  leverageScore       Int?      // 0–10
  leverageExplanation String?   @db.Text
  horizon             String    // "18m" | "12m" | "6m" | "3m"
  status              String    @default("pending")
  // pending | draft_sent | hot_drafted | hot_signed | lease_renewed | no_action | dismissed
  draftGeneratedAt    DateTime?
  hotSignedAt         DateTime?
  leaseSigned         DateTime?
  newRent             Float?
  commissionGbp       Float?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user            User                   @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset           UserAsset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  lease           Lease?                 @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  correspondences RenewalCorrespondence[]

  @@index([userId])
  @@index([assetId])
  @@unique([userId, leaseId, horizon])
}

model RenewalCorrespondence {
  id                 String    @id @default(cuid())
  reviewId           String
  type               String    // "renewal_letter" | "section_25" | "hot" | "response" | "reminder"
  direction          String    // "outbound" | "inbound"
  body               String    @db.Text
  sentAt             DateTime?
  deliveredAt        DateTime?
  openedAt           DateTime?
  docusignEnvelopeId String?
  createdAt          DateTime  @default(now())

  review RentReviewEvent @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model AssetValuation {
  id              String    @id @default(cuid())
  userId          String
  assetId         String
  valuedAt        DateTime  @default(now())
  method          String    // "income_cap" | "psf" | "blended"
  dataSource      String    // "noi" | "attom" | "land_registry"
  avmValue        Float?
  avmLow          Float?
  avmHigh         Float?
  confidenceScore Float?
  capRateUsed     Float?
  capRateSource   String?
  noiEstimate     Float?
  incomeCapValue  Float?
  pricePerSqft    Float?
  sqftValue       Float?
  compsUsed       Int       @default(0)
  notes           String?   @db.Text
  previousValue   Float?
  changeAbsolute  Float?
  changePct       Float?

  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model SellEnquiry {
  id          String   @id @default(cuid())
  userId      String
  assetId     String
  targetPrice Float?
  notes       String?  @db.Text
  status      String   @default("submitted") // "submitted" | "reviewing" | "listed" | "closed" | "withdrawn"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model PlanningApplication {
  id              String    @id @default(cuid())
  userId          String
  assetId         String
  refNumber       String
  description     String    @db.Text
  applicant       String?
  applicantAgent  String?
  applicationType String
  status          String    @default("pending")
  validDate       DateTime?
  decisionDate    DateTime?
  submittedDate   DateTime?
  siteAddress     String?
  postcode        String?
  distanceMetres  Float?
  latitude        Float?
  longitude       Float?
  lpaCode         String?
  lpaName         String?
  country         String?
  dataSource      String    @default("admin")
  sourceRef       String?
  sourceUrl       String?
  impact          String?   // "threat" | "opportunity" | "neutral"
  impactScore     Float?
  impactRationale String?   @db.Text
  holdSellLink    String?   // "sell" | "hold" | "monitor"
  classifiedAt    DateTime?
  lastStatusSeen  String?
  alertSentAt     DateTime?
  alertAcked      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
  @@unique([assetId, sourceRef])
}

// ─── WAVE 2: ENERGY — ANOMALY DETECTION + SOLAR ──────────────────────────────

model EnergyRead {
  id        String   @id @default(cuid())
  userId    String
  assetId   String
  meterId   String
  readAt    DateTime
  kwh       Float
  source    String   // "smart_meter" | "bms" | "submeter" | "manual"
  createdAt DateTime @default(now())

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, readAt(sort: Desc)])
}

model EnergyAnomaly {
  id                String    @id @default(cuid())
  userId            String
  assetId           String
  anomalyType       String    // "overnight_hvac" | "weekend_spike" | "demand_charge" | "hvac_inefficiency" | "tariff_mismatch" | "yoy_spike"
  detectedAt        DateTime  @default(now())
  detectionBasis    String    @db.Text
  annualSavingGbp   Float?
  calculationDetail Json?
  probableCause     String?
  status            String    @default("open") // "open" | "actioned" | "resolved" | "dismissed"
  actionTaken       String?
  resolvedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model SolarAssessment {
  id                       String    @id @default(cuid())
  userId                   String
  assetId                  String    @unique
  assessedAt               DateTime  @default(now())
  roofAreaSqm              Float?
  panelCountEstimate        Int?
  annualGenKwh             Float?
  googleSolarRaw           Json?
  currentUnitRateP         Float?
  segExportRateP           Float?
  selfConsumptionSavingGbp Float?
  exportIncomeGbp          Float?
  installCostGbp           Float?
  paybackYears             Float?
  epcImprovementBands       Int?
  status                   String    @default("viable") // "viable" | "not_viable" | "installed" | "pending"
  notViableReason          String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  user               User               @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset              UserAsset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  solarQuoteRequests SolarQuoteRequest[]

  @@index([userId])
}

model SolarQuoteRequest {
  id              String   @id @default(cuid())
  userId          String
  assetId         String
  assessmentId    String
  requestedAt     DateTime @default(now())
  status          String   @default("pending") // "pending" | "quotes_received" | "approved" | "rejected"
  approvedQuoteId String?
  createdAt       DateTime @default(now())

  user       User            @relation(fields: [userId],       references: [id], onDelete: Cascade)
  asset      UserAsset       @relation(fields: [assetId],      references: [id], onDelete: Cascade)
  assessment SolarAssessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

// ─── WAVE 2: SCOUT COMPARABLES ───────────────────────────────────────────────

model ScoutComparable {
  id            String   @id @default(cuid())
  dealId        String
  address       String
  assetType     String
  sqft          Int?
  salePrice     Float
  saleDate      DateTime
  pricePerSqft  Float?
  capRateAtSale Float?
  source        String   // "land_registry" | "eig" | "costar" | "manual"
  sourceRef     String?
  currency      String   @default("GBP")
  createdAt     DateTime @default(now())

  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

// ─── WAVE 2: SCOUT FINANCE + INVESTORS ───────────────────────────────────────

model DealFinanceModel {
  id              String   @id @default(cuid())
  dealId          String   @unique
  userId          String
  loanAmount      Float
  loanRate        Float    // percentage, e.g., 7.32
  loanTerm        Int      // years
  ltvPct          Float    // percentage, e.g., 65
  equityRequired  Float
  mezzAmount      Float?   // optional mezzanine debt
  mezzRate        Float?   // mezzanine rate
  totalCapital    Float
  leveragedIRR    Float?   // percentage
  cashOnCash      Float?   // percentage
  equityMultiple  Float?   // e.g., 1.85
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([userId])
}

model InvestorContact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String
  company   String?
  type      String   @default("LP") // "LP" | "JV" | "family_office" | "institution"
  status    String   @default("prospect") // "prospect" | "contacted" | "interested" | "committed" | "declined"
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  outreach  InvestorOutreach[]

  @@index([userId])
  @@index([email])
}

model InvestorOutreach {
  id           String    @id @default(cuid())
  investorId   String
  dealId       String
  userId       String
  documentType String    // "im" | "teaser" | "data_room"
  sentAt       DateTime  @default(now())
  openedAt     DateTime?
  responseAt   DateTime?
  status       String    @default("sent") // "sent" | "opened" | "responded" | "declined"
  notes        String?   @db.Text

  investor InvestorContact @relation(fields: [investorId], references: [id], onDelete: Cascade)
  deal     ScoutDeal       @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([investorId])
  @@index([dealId])
  @@index([userId])
}

// ─── WAVE 3: LETTINGS WORKFLOW ────────────────────────────────────────────────

model Letting {
  id              String   @id @default(cuid())
  userId          String
  assetId         String
  unitRef         String?   // for multi-let assets
  status          String    @default("active") // "active" | "under_offer" | "let" | "withdrawn"
  askingRent      Float
  leaseTermYears  Float?
  useClass        String?   // B8, E(g)(i), etc.
  notes           String?   @db.Text
  agreedRent      Float?    // filled on HoT agreed
  agreedTermYears Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  enquiries Enquiry[]

  @@index([userId])
  @@index([assetId])
}

model Enquiry {
  id                 String    @id @default(cuid())
  lettingId          String
  companyName        String
  contactName        String?
  email              String?
  phone              String?
  useCase            String?   // "Distribution hub", "Workshop", "Office" etc.
  covenantGrade      String?   // A/B/C/D from Companies House check
  covenantCheckedAt  DateTime?
  createdAt          DateTime  @default(now())

  letting Letting @relation(fields: [lettingId], references: [id], onDelete: Cascade)

  @@index([lettingId])
}

// ─── WAVE 3 SPRINT 2: COMPLIANCE CERTIFICATES ────────────────────────────────

model ComplianceCertificate {
  id                  String    @id @default(cuid())
  userId              String
  assetId             String
  type                String    // "epc" | "fire_risk" | "gas_safe" | "eicr" | "asbestos" | "legionella" | "insurance"
  status              String    @default("unknown") // "valid" | "expiring" | "expired" | "missing" | "renewal_requested" | "unknown"
  expiryDate          DateTime?
  issuedDate          DateTime?
  issuedBy            String?
  referenceNo         String?
  documentId          String?   // FK to Document (optional)
  renewalNotes        String?   @db.Text
  renewalRequestedAt  DateTime?
  lastVerifiedAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset    UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  @@unique([assetId, type])
  @@index([userId])
  @@index([assetId])
  @@index([expiryDate])
}

// ─── WAVE 3 SPRINT 2: MONTHLY FINANCIALS ─────────────────────────────────────

model MonthlyFinancial {
  id              String   @id @default(cuid())
  userId          String
  assetId         String
  month           Int      // 1–12
  year            Int
  grossRevenue    Float    // rent received + ancillary income
  operatingCosts  Float    // insurance + energy + maintenance for the month
  noi             Float    // grossRevenue - operatingCosts
  maintenanceCost Float    @default(0) // from WorkOrder completions
  insuranceCost   Float    @default(0) // UserAsset.insurancePremium / 12
  energyCost      Float    @default(0) // UserAsset.energyCost / 12
  notes           String?
  source          String   @default("estimated") // "actual" | "estimated" | "extracted"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, month, year])
  @@index([userId])
  @@index([assetId])
}

// ─── FINANCIAL BUDGET (PRO-997) ─────────────────────────────────────────────

model FinancialBudget {
  id                  String   @id @default(cuid())
  userId              String
  year                Int
  budgetedRevenue     Float    @default(0)
  budgetedOpEx        Float    @default(0)
  budgetedNOI         Float    @default(0)
  budgetedInsurance   Float    @default(0)
  budgetedEnergy      Float    @default(0)
  budgetedMaintenance Float    @default(0)
  budgetedManagement  Float    @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year])
  @@index([userId])
}

model Loan {
  id                   String    @id @default(cuid())
  userId               String
  assetId              String?   // Optional: some loans may be portfolio-level
  lender               String
  lenderContact        String?
  outstandingBalance   Float
  originalBalance      Float
  rate                 Float     // Interest rate (percentage)
  rateType             String    // "fixed" | "floating"
  rateReference        String?   // e.g., "SOFR + 225bps" for floating
  spread               Float?    // Spread over benchmark in bps
  termYears            Float
  maturityDate         DateTime
  ltvCovenant          Float?    // LTV covenant threshold (percentage)
  dscrCovenant         Float?    // DSCR covenant threshold (ratio)
  currentLTV           Float?    // Current LTV (percentage)
  currentDSCR          Float?    // Current DSCR (ratio)
  monthlyPayment       Float
  annualDebtService    Float
  prepaymentPenalty    String?   @db.Text
  notes                String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user  User       @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([assetId])
  @@index([maturityDate])
}

model LenderRelationship {
  id              String    @id @default(cuid())
  userId          String
  lenderName      String
  contactName     String?
  contactEmail    String?
  contactPhone    String?
  lastInteraction DateTime?
  notes           String?   @db.Text
  loansCount      Int       @default(0)
  avgRate         Float?
  avgLTV          Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── WAVE 3 SPRINT 3: TRANSACTION ROOM ───────────────────────────────────────

model TransactionRoom {
  id               String    @id @default(cuid())
  userId           String
  dealId           String?   @unique  // FK to ScoutDeal (buy-side)
  assetId          String?            // FK to UserAsset (sell-side)
  type             String             // "acquisition" | "disposal"
  status           String    @default("active") // "active" | "exchanged" | "completed" | "withdrawn"
  askingPrice      Float?
  agreedPrice      Float?
  buyer            String?
  seller           String?
  solicitorRef     String?
  assetName        String?            // Property name for display
  dealAddress      String?            // Property address
  jurisdiction     String?            // "US" | "UK" - for conveyancing checklist variant
  parties          Json?              // [{role, name, company, email, phone}]
  costs            Json?              // [{category, description, estimated, actual, paid, invoiceDocId?, dueDate?}]
  notes            Json?              // [{date, author, text, milestoneId?}]
  expectedTimeline Json?              // {milestoneId: expectedDate}
  viewCount        Int       @default(0)      // Portal view count
  lastViewedAt     DateTime?                  // Last portal view timestamp
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user       User                   @relation(fields: [userId],  references: [id], onDelete: Cascade)
  deal       ScoutDeal?             @relation(fields: [dealId],  references: [id], onDelete: SetNull)
  asset      UserAsset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  documents  TransactionDocument[]
  milestones TransactionMilestone[]
  ndaSignature NDASignature?

  @@index([userId])
  @@index([assetId])
}

model TransactionDocument {
  id           String   @id @default(cuid())
  roomId       String
  documentId   String?  // FK to Document (optional)
  name         String
  category     String   // "nda" | "title_register" | "searches" | "survey" | "contracts" | "enquiries" | "finance" | "other"
  uploadedBy   String   // "owner" | "counterparty" | "solicitor"
  fileUrl      String?  @db.Text
  confidential Boolean  @default(false)
  uploadedAt   DateTime @default(now())

  room TransactionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model TransactionMilestone {
  id                String    @id @default(cuid())
  roomId            String
  stage             String    // "nda" | "heads_of_terms" | "due_diligence" | "legal_exchange" | "completion"
  status            String    @default("pending") // "pending" | "in_progress" | "complete"
  completedAt       DateTime?
  dueDate           DateTime? // v2: expected completion date for this milestone
  notes             String?   @db.Text
  tasks             Json?     // v2: {id, label, completed, completedAt, completedBy: "system"|"user", isAutomatic}[]
  expectedDocuments Json?     // v2: {type, label, required, documentId}[]
  createdAt         DateTime  @default(now())

  room TransactionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model NDASignature {
  id          String    @id @default(cuid())
  roomId      String    @unique
  signerName  String
  signerEmail String
  signedAt    DateTime?
  docusignId  String?
  status      String    @default("pending") // "pending" | "sent" | "signed" | "declined"
  createdAt   DateTime  @default(now())

  room TransactionRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

// ─── EMAIL TRACKING (PRO-766) ────────────────────────────────────────────────

model EmailTracking {
  id              String    @id @default(cuid())
  userId          String
  messageId       String    @unique // Resend message ID
  from            String
  to              String
  subject         String?
  emailType       String?   // "rent_review" | "work_order" | "transaction" | etc
  referenceId     String?   // FK to related entity (reviewId, workOrderId, etc)
  status          String    @default("sent") // "sent" | "delivered" | "delayed" | "bounced" | "complained" | "opened" | "clicked"
  sentAt          DateTime  @default(now())
  deliveredAt     DateTime?
  bouncedAt       DateTime?
  bouncedReason   String?
  complainedAt    DateTime?
  openedAt        DateTime?
  clickedAt       DateTime?
  lastEventAt     DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([messageId])
  @@index([referenceId])
  @@index([emailType])
}

// ─── DEALSCOPE: APPROACH LETTERS ─────────────────────────────────────────────

model ApproachLetter {
  id                String    @id @default(cuid())
  userId            String
  dealId            String
  letterContent     String    @db.Text
  tone              String    @default("formal") // "formal" | "direct" | "consultative"
  recipientName     String?
  recipientEmail    String?
  recipientAddress  String?   @db.Text
  generatedAt       DateTime  @default(now())
  sentAt            DateTime?
  sentVia           String?   // "email" | "post" | null if not sent
  responseStatus    String?   // "interested" | "not_interested" | "maybe" | "no_response"
  followUpDate      DateTime?
  notes             String?   @db.Text
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dealId])
  @@index([sentAt])
}

// ── DealScope Analysis Models ────────────────────────────────────────────

model PropertyValuation {
  id             String   @id @default(cuid())
  propertyId     String   // FK to ScoutDeal
  valuationLow   Float
  valuationMid   Float
  valuationHigh  Float
  method         String   // "comparables" | "income" | "residual" | "hybrid"
  confidence     Float    // 0-1
  createdAt      DateTime @default(now())

  @@index([propertyId])
}

model PropertyRentGap {
  id              String   @id @default(cuid())
  propertyId      String   // FK to ScoutDeal
  currentRentPsf  Float
  marketRentPsf   Float
  gapPsf          Float
  gapPercentage   Float
  guess           String   // "over-rented" | "market" | "under-rented"
  epcRating       String?
  buildingAge     Int?
  occupancy       Float?
  tenantStrength  String?  // "strong" | "satisfactory" | "weak"
  createdAt       DateTime @default(now())

  @@index([propertyId])
}

model UserPipeline {
  id         String   @id @default(cuid())
  userId     String
  propertyId String   // FK to ScoutDeal
  stage      String   // "identified" | "researched" | "approached" | "negotiating" | "under_offer" | "completing"
  mandateId  String?  // Optional link to SavedSearch
  followUpDate DateTime?
  addedAt    DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  property  ScoutDeal           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  responses PipelineResponse[]
  notes     PipelineNote[]
  stageLogs PipelineStageLog[]

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
  @@index([stage])
}

model PipelineResponse {
  id         String   @id @default(cuid())
  pipelineId String
  status     String   // "pending" | "interested" | "not_interested" | "followup"
  note       String?
  followUpDate DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  pipeline UserPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
}
// ─── LAND REGISTRY: BULK DATA ───────────────────────────────────────────────

model LandRegistryPricePaid {
  id                String   @id @default(cuid())
  // Core transaction fields (from HM Land Registry dataset)
  transactionId     String   @unique // TOID
  price             Float
  transferDate      DateTime
  address           String
  postcode          String
  postcodeSector    String   // e.g. "SW1A" for geospatial lookups
  propertyType      String   // "Detached" | "Semi-detached" | "Terraced" | "Flat" | "Other"
  isNew             Boolean  // true if new property, false if existing
  // Indexing fields for fast comps lookup
  lat               Float?
  lng               Float?
  sqft              Int?
  // Meta
  source            String   @default("land_registry")
  importedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Indexes for fast comparable sales lookups
  @@index([postcodeSector, propertyType, transferDate])
  @@index([postcode])
  @@index([transferDate])
  @@index([lat, lng]) // For radius-based searches
}

model LandRegistryCCOD {
  id                String   @id @default(cuid())
  // Core ownership fields (from CCOD dataset)
  titleNumber       String   // Unique property identifier
  companyNumber     String   // Companies House reference
  companyName       String
  address           String
  postcode          String
  postcodeSector    String
  county            String?
  // Lookup fields
  lat               Float?
  lng               Float?
  // Meta
  source            String   @default("land_registry")
  importedAt        DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Indexes for fast owner lookups
  @@index([companyNumber])
  @@index([postcodeSector])
  @@index([address])
  @@unique([titleNumber, companyNumber]) // One company per title
}

// ─── DEALSCOPE: SAVED SEARCHES & ALERTS ───────────────────────────────────

model SavedSearch {
  id          String   @id @default(cuid())
  userId      String
  name        String   // e.g., "SE Industrial <£800k"
  clientName  String?  // For agents managing on behalf of client
  criteria    Json     // {sources:[], assetClasses:[], locations:[], priceMin, priceMax, sizeMin, sizeMax, epcFilter:[], minScore, yieldMin, yieldMax, excludes:[]}
  alertEmail  Boolean  @default(true)
  alertDigest String   @default("daily") // "daily" | "weekly" | "off"
  alertUrgent Boolean  @default(true)
  alertInApp  Boolean  @default(true)
  paused      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts AlertEvent[]

  @@index([userId])
}

model AlertEvent {
  id            String   @id @default(cuid())
  userId        String
  mandateId     String?  // Link to SavedSearch (mandate)
  propertyId    String?  // Link to ScoutDeal
  type          String   // "signal_match" | "price_change" | "status_change" | "deadline" | "portfolio" | "followup" | "completion"
  title         String   // e.g., "Admin filing: Meridian Business Park"
  description   String   // e.g., "Company entered administration on 2026-03-15"
  metadata      Json?    // {oldPrice, newPrice, daysLeft, etc}
  read          Boolean  @default(false)
  dismissed     Boolean  @default(false)
  snoozedUntil  DateTime?
  createdAt     DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mandate  SavedSearch? @relation(fields: [mandateId], references: [id], onDelete: SetNull)
  property ScoutDeal?   @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([read])
}

model PropertyWatchlist {
  id         String   @id @default(cuid())
  userId     String
  propertyId String   // FK to ScoutDeal
  reasons    String[] // ["price_change", "admin_resolution", "auction_listing"]
  note       String?
  createdAt  DateTime @default(now())

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  property ScoutDeal @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
}

model PipelineNote {
  id         String   @id @default(cuid())
  pipelineId String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  pipeline UserPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
}

model PipelineStageLog {
  id         String   @id @default(cuid())
  pipelineId String
  fromStage  String?
  toStage    String
  createdAt  DateTime @default(now())

  pipeline UserPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
}

model PortfolioProperty {
  id           String   @id @default(cuid())
  userId       String
  address      String
  type         String   // "industrial" | "office" | "retail" | "warehouse" | "mixed" | "residential"
  location     String
  value        Float
  acquiredDate DateTime?
  elevateId    String?  // Cross-reference to Elevate
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditBalance {
  id               String   @id @default(cuid())
  userId           String   @unique
  balance          Float    @default(50)
  tier             String   @default("free") // "free" | "starter" | "pro" | "team" | "enterprise"
  monthlyAllowance Float    @default(50)
  resetDate        DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Float    // negative = deduction, positive = top-up/reset
  action      String   // "enrich" | "ai_analysis" | "letter_gen" | "comps" | "pdf" | "xlsx" | "watch_alert" | "mandate_alert" | "monthly_reset" | "topup" | "upgrade"
  propertyId  String?  // Which property this was for
  metadata    Json?    // {enrichSources: [...], letterType: "admin", pdfType: "memo"}
  balanceAfter Float   // Balance after this transaction
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
