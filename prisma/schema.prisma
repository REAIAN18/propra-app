generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // RealHQ-specific fields
  portfolio     Portfolio @default(FL_MIXED)
  isAdmin       Boolean   @default(false)
  onboardedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  documents        Document[]
  userAssets       UserAsset[]
  insuranceQuotes  InsuranceQuote[]
  energyQuotes     EnergyQuote[]
  commissions      Commission[]
  acquisitions     Acquisition[]
  workOrders               WorkOrder[]
  incomeActivations        IncomeActivation[]
  tenantEngagementActions  TenantEngagementAction[]
  scoutReactions           ScoutReaction[]
  tenants                  Tenant[]
  leases                   Lease[]
  tenantPayments           TenantPayment[]
  tenantEngagements        TenantEngagement[]
  scoutUnderwritings       ScoutUnderwriting[]
  scoutLois                ScoutLOI[]
  holdSellScenarios        HoldSellScenario[]
  rentReviewEvents         RentReviewEvent[]
  assetValuations          AssetValuation[]
  planningApplications     PlanningApplication[]
  sellEnquiries            SellEnquiry[]
}

enum Portfolio {
  FL_MIXED
  SE_LOGISTICS
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model SignupLead {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  phone          String?
  company        String?
  assetCount     Int?
  portfolioValue String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Unsubscribe {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ScheduledEmail {
  id           String    @id @default(cuid())
  to           String
  from         String
  subject      String
  html         String    @db.Text
  text         String    @db.Text
  sendAfter    DateTime
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  prospectKey  String?
  touchNumber  Int?
  market       String?

  @@index([sendAfter, sentAt])
}

model AuditLead {
  id              String   @id @default(cuid())
  email           String
  portfolioInput  String
  assetType       String?
  assetCount      Int?
  estimateTotal   Int?
  estimateJson    String?
  enrichmentsJson String?  @db.Text
  createdAt       DateTime @default(now())
}


model Document {
  id            String   @id @default(cuid())
  userId        String?
  filename      String
  fileSize      Int
  mimeType      String
  documentType  String?
  summary       String?
  extractedData Json?
  extractedJson String?  @db.Text
  status        String   @default("pending")
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAssets UserAsset[]
  extracts   DocumentExtract[]
}

model DocumentExtract {
  id             String   @id @default(cuid())
  documentId     String
  type           String   // "insurance" | "energy" | "lease" | "other"
  rawText        String?  @db.Text
  structuredJson Json?
  confidence     Float?
  extractedAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ProspectStatus {
  id              String   @id @default(cuid())
  prospectKey     String   @unique
  status          String
  notes           String?  @db.Text
  linkedinSent    Boolean  @default(false)
  emailSent       Boolean  @default(false)
  touch1SentAt    String?
  touch2SentAt    String?
  touch3SentAt    String?
  emailOpened     Boolean  @default(false)
  emailClicked    Boolean  @default(false)
  emailBounced    Boolean  @default(false)
  lastContact     String?
  emailOverride    String?
  linkedinOverride String?
  manualStatus     String?
  manualNote       String?  @db.Text
  manualUpdatedAt  DateTime?
  updatedAt        DateTime @updatedAt
  updatedBy        String?
}

model UserAsset {
  id               String    @id @default(cuid())
  userId           String
  name             String
  assetType        String
  location         String
  sqft             Int?
  grossIncome      Int?
  netIncome        Int?
  passingRent      Float?
  marketERV        Float?
  insurancePremium Int?
  marketInsurance  Int?
  energyCost       Int?
  marketEnergyCost Int?
  occupancy        Float?
  sourceDocumentId String?
  // Property detail fields (PRO-251)
  address          String?
  postcode         String?
  country          String?   @default("UK")
  latitude         Float?
  longitude        Float?
  epcRating        String?
  epcFetched       Boolean   @default(false)
  formattedAddress String?
  epcExpiry        DateTime?
  floodRisk        String?
  floodZone        String?
  femaZoneRaw      Json?
  planningHistory  Json?
  satelliteUrl     String?
  marketCapRate    Float?
  marketRentSqft   Float?
  // Wave 2 fields
  meterType            String?   // "hh" | "sme"
  planningImpactSignal String?   // "positive" | "neutral" | "negative"
  planningLastFetched  DateTime?
  avmValue             Float?
  avmLow               Float?
  avmHigh              Float?
  avmDate              DateTime?
  avmConfidence        Float?
  pipelineStage        String?
  pipelineUpdatedAt    DateTime?
  brochureDocId        String?
  tenantCount          Int?
  wault                Float?
  region               String?   // "se_uk" | "fl_us"
  // Insurance risk scorecard (Wave 2 — PRO-610)
  insuranceRiskScore      Float?
  insuranceRiskFactors    Json?
  insuranceRoadmap        Json?
  insuranceRiskAssessedAt DateTime?
  // Development potential (Wave 2 — PRO-604)
  siteCoveragePct        Float?
  pdRights               String?
  pdRightsDetail         String?   @db.Text
  changeOfUsePotential   String?
  changeOfUseDetail      String?   @db.Text
  airRightsPotential     String?
  airRightsDetail        String?   @db.Text
  devPotentialAssessedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceDocument    Document?         @relation(fields: [sourceDocumentId], references: [id])
  insuranceQuotes   InsuranceQuote[]
  energyQuotes      EnergyQuote[]
  commissions       Commission[]
  comparables          PropertyComparable[]
  valuations           AssetValuation[]
  planningApplications PlanningApplication[]
  workOrders           WorkOrder[]
  incomeActivations  IncomeActivation[]
  tenants            Tenant[]
  leases             Lease[]
  holdSellScenario   HoldSellScenario?
  rentReviewEvents   RentReviewEvent[]
  sellEnquiries      SellEnquiry[]

  @@unique([userId, name])
}

model PropertyComparable {
  id           String   @id @default(cuid())
  assetId      String
  attomId      String?
  address      String
  sqft         Int?
  yearBuilt    Int?
  saleAmount   Float?
  saleDate     String?  // YYYY-MM-DD
  pricePerSqft Float?
  source       String   @default("attom")
  fetchedAt    DateTime @default(now())

  asset        UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@unique([assetId, source, address])
}

model InsuranceQuote {
  id               String   @id @default(cuid())
  userId           String
  assetId          String?
  carrier          String
  quoteRef         String?
  policyType       String?
  currentPremium   Float?
  quotedPremium    Float
  annualSaving     Float?
  coverageDetails  Json?
  dataSource       String   @default("benchmark") // "benchmark" | "live_api"
  status           String   @default("pending")   // "pending" | "bound" | "declined" | "expired"
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model EnergyQuote {
  id              String   @id @default(cuid())
  userId          String
  assetId         String?
  supplier        String
  currentSupplier String?
  currentRate     Float?
  quotedRate      Float
  annualUsage     Float?
  currentCost     Float?
  quotedCost      Float
  annualSaving    Float?
  dataSource      String   @default("benchmark") // "benchmark" | "live_api"
  status          String   @default("pending")   // "pending" | "switched" | "declined" | "expired"
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset  UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model Commission {
  id              String   @id @default(cuid())
  userId          String
  assetId         String?
  category        String   // "insurance" | "energy" | "rent" | "ancillary"
  sourceId        String?  // FK to InsuranceQuote.id or EnergyQuote.id
  annualSaving    Float
  commissionRate  Float    @default(0.15)
  commissionValue Float
  status          String   @default("pending") // "pending" | "confirmed" | "invoiced" | "paid"
  placedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model ClientPortfolio {
  id        String   @id @default(cuid())
  name      String   // "Starlight Industrial Holdings"
  urlKey    String   @unique // "starlight-industrial"
  data      Json     // serialized Portfolio type
  createdBy String?  // admin email
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MacroRate {
  id        String   @id @default(cuid())
  series    String   // e.g. "SOFR"
  value     Float    // rate in percent, e.g. 5.30
  date      String   // YYYY-MM-DD as reported by FRED
  fetchedAt DateTime @default(now())

  @@unique([series, date])
}

model Acquisition {
  id            String   @id @default(cuid())
  userId        String
  name          String
  location      String
  assetType     String   // "industrial" | "warehouse" | "office" | "retail" | "flex" | "mixed"
  sqft          Int?
  askingPrice   Float
  estimatedYield Float
  marketYield   Float?
  score         Int?     // 0–100 fit score
  status        String   @default("screening") // "screening" | "loi" | "due_diligence" | "exchange" | "passed"
  rationale     String?  @db.Text
  noi           Float?
  currency      String   @default("USD") // "USD" | "GBP"
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IncomeActivation {
  id               String   @id @default(cuid())
  userId           String
  assetId          String?
  opportunityType  String   // "5g_mast" | "ev_charging" | "solar" | "parking" | "billboard" | "scan"
  opportunityLabel String?
  annualIncome     Float?
  status           String   @default("requested") // "requested" | "in_progress" | "live" | "declined"
  requestedAt      DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model WorkOrder {
  id               String   @id @default(cuid())
  userId           String
  assetId          String?
  tenderType       String?  // "MAINTENANCE" | "COMPLIANCE" | "CAPITAL_WORKS" | "CONSTRUCTION" | "GREEN_ESG" | "PROFESSIONAL"
  jobType          String   // specific job e.g. "HVAC Service"
  description      String   @db.Text
  scopeOfWorks     String?  @db.Text  // RealHQ-structured formal brief
  accessNotes      String?
  timing           String?
  targetStart      String?  // YYYY-MM-DD
  budgetEstimate   Float?
  benchmarkLow     Float?
  benchmarkHigh    Float?
  benchmarkSource  String?
  capRateValueAdd  Float?   // asset value uplift for capital works (£/$)
  status           String   @default("draft")
  // draft | tendered | quotes_received | awarded | in_progress | complete
  contractor       String?
  costEstimate     Float?
  currency         String   @default("GBP")
  autoTriggerFrom  String?  // "compliance" | "energy" | "income" | "planning"
  autoTriggerRef   String?
  agreedPrice      Float?   // price agreed after bid selection
  contractorId     String?  // winning contractor FK (soft link to Contractor.id)
  finalCost        Float?   // actual final cost on completion
  aiScopeJson      Json?    // structured scope from POST /scope: { scopeSummary, lineItems, totalEstimate, tradeRequired, urgency }
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset      UserAsset?           @relation(fields: [assetId], references: [id], onDelete: SetNull)
  quotes     TenderQuote[]
  milestones WorkOrderMilestone[]
  completion WorkOrderCompletion?
}

model TenderQuote {
  id             String    @id @default(cuid())
  workOrderId    String
  contractorName String
  price          Float
  warranty       String?   // e.g. "12 months"
  timeline       String?   // e.g. "2 weeks"
  rating         Float?    // e.g. 4.8
  notes          String?   @db.Text
  awarded        Boolean   @default(false)
  createdAt      DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model TenantEngagementAction {
  id          String   @id @default(cuid())
  userId      String
  leaseRef    String   // synthetic lease ID from lease-summary (doc.id or docId-N)
  actionType  String   // "engage_renewal" | "relet" | "review_break"
  status      String   @default("requested") // "requested" | "completed"
  requestedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, leaseRef])
}

// ── Scout feed ────────────────────────────────────────────────────────
model ScoutDeal {
  id                     String   @id @default(cuid())
  externalId             String?  @unique // LoopNet listing ID or similar for dedup
  address                String
  assetType              String   // "industrial" | "warehouse" | "office" | "retail" | "flex" | "mixed"
  sqft                   Int?
  askingPrice            Float?
  guidePrice             Float?
  capRate                Float?   // cap rate percentage e.g. 6.5
  brokerName             String?  // listing broker/agent name
  daysOnMarket           Int?
  sourceTag              String   // "Auction" | "Pre-market" | "Planning signal" | "Distressed" | "LoopNet"
  sourceUrl              String?
  hasLisPendens          Boolean  @default(false)
  hasInsolvency          Boolean  @default(false)
  lastSaleYear           Int?
  hasPlanningApplication Boolean  @default(false)
  solarIncomeEstimate    Float?   // annual £
  inFloodZone            Boolean  @default(false)
  auctionDate            DateTime?
  ownerName              String?
  satelliteImageUrl      String?
  signalCount            Int      @default(0) // 0-5 for intelligence dots
  currency               String   @default("GBP")
  status                 String   @default("active") // "active" | "removed"
  // Wave 2 fields
  pipelineStage          String?
  pipelineUpdatedAt      DateTime?
  brochureDocId          String?
  region                 String?  // "se_uk" | "fl_us"
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  reactions     ScoutReaction[]
  underwriting  ScoutUnderwriting?
  lois          ScoutLOI[]
}

model ScoutReaction {
  id        String   @id @default(cuid())
  userId    String
  dealId    String
  reaction  String   // "interested" | "passed"
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
  @@index([userId])
}

// ─── WAVE 2: WORK ORDERS ────────────────────────────────────────────────────

model Contractor {
  id        String   @id @default(cuid())
  name      String
  region    String   // "se_uk" | "fl_us"
  trades    String[] // ["HVAC", "Electrical", "Roofing", ...]
  email     String
  phone     String?
  rating    Float    @default(4.0)
  jobCount  Int      @default(0)
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([region])
}

model WorkOrderMilestone {
  id          String    @id @default(cuid())
  workOrderId String
  title       String
  description String?
  dueDate     DateTime?
  completedAt DateTime?
  status      String    @default("pending") // "pending" | "in_progress" | "complete"
  createdAt   DateTime  @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
}

model WorkOrderCompletion {
  id                    String   @id @default(cuid())
  workOrderId           String   @unique
  contractorId          String?
  finalCost             Float
  completionNotes       String?  @db.Text
  contractorRatingGiven Float?
  goCardlessPaymentId   String?
  completedAt           DateTime @default(now())

  workOrder WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

// ─── WAVE 2: TENANT INTELLIGENCE ────────────────────────────────────────────

model Tenant {
  id                String    @id @default(cuid())
  userId            String
  assetId           String?
  name              String
  companyNumber     String?
  covenantGrade     String?   // "strong" | "satisfactory" | "weak" | "unknown"
  covenantScore     Float?
  covenantCheckedAt DateTime?
  sector            String?
  email             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user        User          @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset       UserAsset?    @relation(fields: [assetId], references: [id], onDelete: SetNull)
  leases      Lease[]
  payments    TenantPayment[]
  engagements TenantEngagement[]

  @@unique([userId, name])
  @@index([userId])
}

model Lease {
  id          String    @id @default(cuid())
  userId      String
  tenantId    String
  assetId     String
  documentId  String?
  leaseRef    String?
  sqft        Int       @default(0)
  passingRent Float     @default(0)
  rentPerSqft Float?
  startDate   DateTime?
  expiryDate  DateTime?
  breakDate   DateTime?
  reviewDate  DateTime?
  currency    String?
  status      String    @default("active") // "active" | "expiring_soon" | "expired" | "vacant"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User          @relation(fields: [userId],   references: [id], onDelete: Cascade)
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asset       UserAsset     @relation(fields: [assetId],  references: [id], onDelete: Cascade)
  payments    TenantPayment[]
  engagements TenantEngagement[]
  rentReviews RentReviewEvent[]

  @@index([userId])
  @@index([tenantId])
  @@index([assetId])
}

model TenantPayment {
  id          String    @id @default(cuid())
  tenantId    String
  leaseId     String
  userId      String
  amount      Float
  dueDate     DateTime
  paidDate    DateTime?
  periodStart DateTime
  status      String    @default("pending") // "pending" | "paid" | "late" | "missed"
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease  Lease  @relation(fields: [leaseId],  references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)

  @@index([leaseId])
  @@index([tenantId])
}

model TenantEngagement {
  id          String    @id @default(cuid())
  tenantId    String
  leaseId     String
  userId      String
  actionType  String    // "engage_renewal" | "serve_review" | "send_letter"
  letterDraft String?   @db.Text
  emailSentAt DateTime?
  status      String    @default("draft") // "draft" | "sent" | "responded" | "complete"
  createdAt   DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lease  Lease  @relation(fields: [leaseId],  references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId],   references: [id], onDelete: Cascade)

  @@index([leaseId])
}

model TenantLetter {
  id          String    @id @default(cuid())
  leaseId     String
  tenantId    String
  userId      String
  assetId     String?
  type        String    // "rent_review" | "renewal" | "re_gear" | "break_notice"
  body        String    @db.Text
  status      String    @default("draft") // "draft" | "sent"
  sentAt      DateTime?
  sentToEmail String?
  createdAt   DateTime  @default(now())

  @@index([leaseId])
  @@index([tenantId])
}

// ─── WAVE 2: SCOUT UNDERWRITING ─────────────────────────────────────────────

model ScoutUnderwriting {
  id            String   @id @default(cuid())
  dealId        String   @unique
  userId        String
  passedRentPa  Float?
  vacancyRate   Float?
  opexPct       Float?
  capexEstimate Float?
  noiGross      Float?
  noinet        Float?
  capRate       Float?
  marketCapRate Float?
  capRateGap    Float?
  yieldOnCost   Float?
  grossYield    Float?
  dscr          Float?
  irr5yr        Float?
  dataSource    String   @default("estimated")
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoutLOI {
  id                String   @id @default(cuid())
  dealId            String
  userId            String
  offerPrice        Float
  depositPct        Float    @default(0.10)
  conditionalDays   Int      @default(28)
  completionDays    Int      @default(90)
  specialConditions String?  @db.Text
  body              String   @db.Text
  status            String   @default("draft") // "draft" | "sent" | "accepted" | "withdrawn"
  createdAt         DateTime @default(now())

  deal ScoutDeal @relation(fields: [dealId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dealId, userId])
}

// ─── WAVE 2: HOLD VS SELL ────────────────────────────────────────────────────

model HoldSellScenario {
  id                  String   @id @default(cuid())
  assetId             String   @unique
  userId              String
  // Hold scenario outputs
  holdNPV             Float?
  holdIRR             Float?
  holdEquityMultiple  Float?
  holdCashYield       Float?
  // Sell scenario outputs
  estimatedSalePrice  Float?
  sellNetProceeds     Float?
  sellRedeployedNPV   Float?
  sellIRR             Float?
  sellEquityMultiple  Float?
  // Summary
  recommendation      String?  // "strong_hold" | "hold" | "sell" | "needs_review"
  rationale           String?  @db.Text
  confidenceScore     Float?
  dataSource          String?  // "avm" | "estimated"
  // User assumptions (stored for next recalc)
  holdPeriodYears     Float?
  rentGrowthPct       Float?
  exitYield           Float?
  vacancyAllowance    Float?
  capexSchedule       Float?
  sellingCostsPct     Float?
  redeploymentYield   Float?
  lastCalculatedAt    DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
}

// ─── WAVE 2: RENT REVIEW AUTOMATION ─────────────────────────────────────────

model RentReviewEvent {
  id                  String    @id @default(cuid())
  userId              String
  assetId             String?
  leaseId             String?
  tenantName          String
  propertyAddress     String?
  expiryDate          DateTime
  breakDate           DateTime?
  passingRent         Float
  sqft                Int?
  ervLive             Float?
  ervSource           String?   // "costar" | "attom" | "msci" | "manual"
  ervFetchedAt        DateTime?
  gap                 Float?    // annual uplift at ERV
  leverageScore       Int?      // 0–10
  leverageExplanation String?   @db.Text
  horizon             String    // "18m" | "12m" | "6m" | "3m"
  status              String    @default("pending")
  // pending | draft_sent | hot_drafted | hot_signed | lease_renewed | no_action | dismissed
  draftGeneratedAt    DateTime?
  hotSignedAt         DateTime?
  leaseSigned         DateTime?
  newRent             Float?
  commissionGbp       Float?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user            User                   @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset           UserAsset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)
  lease           Lease?                 @relation(fields: [leaseId], references: [id], onDelete: SetNull)
  correspondences RenewalCorrespondence[]

  @@index([userId])
  @@index([assetId])
  @@unique([userId, leaseId, horizon])
}

model RenewalCorrespondence {
  id                 String    @id @default(cuid())
  reviewId           String
  type               String    // "renewal_letter" | "section_25" | "hot" | "response" | "reminder"
  direction          String    // "outbound" | "inbound"
  body               String    @db.Text
  sentAt             DateTime?
  deliveredAt        DateTime?
  openedAt           DateTime?
  docusignEnvelopeId String?
  createdAt          DateTime  @default(now())

  review RentReviewEvent @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
}

model AssetValuation {
  id              String    @id @default(cuid())
  userId          String
  assetId         String
  valuedAt        DateTime  @default(now())
  method          String    // "income_cap" | "psf" | "blended"
  dataSource      String    // "noi" | "attom" | "land_registry"
  avmValue        Float?
  avmLow          Float?
  avmHigh         Float?
  confidenceScore Float?
  capRateUsed     Float?
  capRateSource   String?
  noiEstimate     Float?
  incomeCapValue  Float?
  pricePerSqft    Float?
  sqftValue       Float?
  compsUsed       Int       @default(0)
  notes           String?   @db.Text
  previousValue   Float?
  changeAbsolute  Float?
  changePct       Float?

  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model SellEnquiry {
  id          String   @id @default(cuid())
  userId      String
  assetId     String
  targetPrice Float?
  notes       String?  @db.Text
  status      String   @default("submitted") // "submitted" | "reviewing" | "listed" | "closed" | "withdrawn"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
}

model PlanningApplication {
  id              String    @id @default(cuid())
  userId          String
  assetId         String
  refNumber       String
  description     String    @db.Text
  applicant       String?
  applicantAgent  String?
  applicationType String
  status          String    @default("pending")
  validDate       DateTime?
  decisionDate    DateTime?
  submittedDate   DateTime?
  siteAddress     String?
  postcode        String?
  distanceMetres  Float?
  latitude        Float?
  longitude       Float?
  lpaCode         String?
  lpaName         String?
  country         String?
  dataSource      String    @default("admin")
  sourceRef       String?
  sourceUrl       String?
  impact          String?   // "threat" | "opportunity" | "neutral"
  impactScore     Float?
  impactRationale String?   @db.Text
  holdSellLink    String?   // "sell" | "hold" | "monitor"
  classifiedAt    DateTime?
  lastStatusSeen  String?
  alertSentAt     DateTime?
  alertAcked      Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user  User      @relation(fields: [userId],  references: [id], onDelete: Cascade)
  asset UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([assetId])
  @@unique([assetId, sourceRef])
}
