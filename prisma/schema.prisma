generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // RealHQ-specific fields
  portfolio     Portfolio @default(FL_MIXED)
  isAdmin       Boolean   @default(false)
  onboardedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  documents        Document[]
  userAssets       UserAsset[]
  insuranceQuotes  InsuranceQuote[]
  energyQuotes     EnergyQuote[]
  commissions      Commission[]
  acquisitions     Acquisition[]
  workOrders       WorkOrder[]
}

enum Portfolio {
  FL_MIXED
  SE_LOGISTICS
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model SignupLead {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  phone          String?
  company        String
  assetCount     Int?
  portfolioValue String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Unsubscribe {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model ScheduledEmail {
  id           String    @id @default(cuid())
  to           String
  from         String
  subject      String
  html         String    @db.Text
  text         String    @db.Text
  sendAfter    DateTime
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  prospectKey  String?
  touchNumber  Int?
  market       String?

  @@index([sendAfter, sentAt])
}

model AuditLead {
  id              String   @id @default(cuid())
  email           String
  portfolioInput  String
  assetType       String?
  assetCount      Int?
  estimateTotal   Int?
  estimateJson    String?
  enrichmentsJson String?  @db.Text
  createdAt       DateTime @default(now())
}


model Document {
  id            String   @id @default(cuid())
  userId        String?
  filename      String
  fileSize      Int
  mimeType      String
  documentType  String?
  summary       String?
  extractedData Json?
  extractedJson String?  @db.Text
  status        String   @default("pending")
  error         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user       User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAssets UserAsset[]
  extracts   DocumentExtract[]
}

model DocumentExtract {
  id             String   @id @default(cuid())
  documentId     String
  type           String   // "insurance" | "energy" | "lease" | "other"
  rawText        String?  @db.Text
  structuredJson Json?
  confidence     Float?
  extractedAt    DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ProspectStatus {
  id              String   @id @default(cuid())
  prospectKey     String   @unique
  status          String
  notes           String?  @db.Text
  linkedinSent    Boolean  @default(false)
  emailSent       Boolean  @default(false)
  touch1SentAt    String?
  touch2SentAt    String?
  touch3SentAt    String?
  emailOpened     Boolean  @default(false)
  emailClicked    Boolean  @default(false)
  emailBounced    Boolean  @default(false)
  lastContact     String?
  emailOverride    String?
  linkedinOverride String?
  manualStatus     String?
  manualNote       String?  @db.Text
  manualUpdatedAt  DateTime?
  updatedAt        DateTime @updatedAt
  updatedBy        String?
}

model UserAsset {
  id               String    @id @default(cuid())
  userId           String
  name             String
  assetType        String
  location         String
  sqft             Int?
  grossIncome      Int?
  netIncome        Int?
  passingRent      Float?
  marketERV        Float?
  insurancePremium Int?
  marketInsurance  Int?
  energyCost       Int?
  marketEnergyCost Int?
  occupancy        Float?
  sourceDocumentId String?
  // Property detail fields (PRO-251)
  address          String?
  postcode         String?
  country          String?   @default("UK")
  latitude         Float?
  longitude        Float?
  epcRating        String?
  epcFetched       Boolean   @default(false)
  formattedAddress String?
  epcExpiry        DateTime?
  floodRisk        String?
  floodZone        String?
  femaZoneRaw      Json?
  planningHistory  Json?
  satelliteUrl     String?
  marketCapRate    Float?
  marketRentSqft   Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceDocument    Document?         @relation(fields: [sourceDocumentId], references: [id])
  insuranceQuotes   InsuranceQuote[]
  energyQuotes      EnergyQuote[]
  commissions       Commission[]
  comparables       PropertyComparable[]
  workOrders        WorkOrder[]

  @@unique([userId, name])
}

model PropertyComparable {
  id           String   @id @default(cuid())
  assetId      String
  attomId      String?
  address      String
  sqft         Int?
  yearBuilt    Int?
  saleAmount   Float?
  saleDate     String?  // YYYY-MM-DD
  pricePerSqft Float?
  source       String   @default("attom")
  fetchedAt    DateTime @default(now())

  asset        UserAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
}

model InsuranceQuote {
  id               String   @id @default(cuid())
  userId           String
  assetId          String?
  carrier          String
  quoteRef         String?
  policyType       String?
  currentPremium   Float?
  quotedPremium    Float
  annualSaving     Float?
  coverageDetails  Json?
  dataSource       String   @default("benchmark") // "benchmark" | "live_api"
  status           String   @default("pending")   // "pending" | "bound" | "declined" | "expired"
  expiresAt        DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset     UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model EnergyQuote {
  id              String   @id @default(cuid())
  userId          String
  assetId         String?
  supplier        String
  currentSupplier String?
  currentRate     Float?
  quotedRate      Float
  annualUsage     Float?
  currentCost     Float?
  quotedCost      Float
  annualSaving    Float?
  dataSource      String   @default("benchmark") // "benchmark" | "live_api"
  status          String   @default("pending")   // "pending" | "switched" | "declined" | "expired"
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset  UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model Commission {
  id              String   @id @default(cuid())
  userId          String
  assetId         String?
  category        String   // "insurance" | "energy" | "rent" | "ancillary"
  sourceId        String?  // FK to InsuranceQuote.id or EnergyQuote.id
  annualSaving    Float
  commissionRate  Float    @default(0.15)
  commissionValue Float
  status          String   @default("pending") // "pending" | "confirmed" | "invoiced" | "paid"
  placedAt        DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}

model ClientPortfolio {
  id        String   @id @default(cuid())
  name      String   // "Starlight Industrial Holdings"
  urlKey    String   @unique // "starlight-industrial"
  data      Json     // serialized Portfolio type
  createdBy String?  // admin email
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MacroRate {
  id        String   @id @default(cuid())
  series    String   // e.g. "SOFR"
  value     Float    // rate in percent, e.g. 5.30
  date      String   // YYYY-MM-DD as reported by FRED
  fetchedAt DateTime @default(now())

  @@unique([series, date])
}

model Acquisition {
  id            String   @id @default(cuid())
  userId        String
  name          String
  location      String
  assetType     String   // "industrial" | "warehouse" | "office" | "retail" | "flex" | "mixed"
  sqft          Int?
  askingPrice   Float
  estimatedYield Float
  marketYield   Float?
  score         Int?     // 0–100 fit score
  status        String   @default("screening") // "screening" | "loi" | "due_diligence" | "exchange" | "passed"
  rationale     String?  @db.Text
  noi           Float?
  currency      String   @default("USD") // "USD" | "GBP"
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkOrder {
  id             String   @id @default(cuid())
  userId         String
  assetId        String?
  jobType        String   // "Maintenance" | "Refurbishment" | "Fitout" | "Other"
  description    String   @db.Text
  targetStart    String?  // YYYY-MM-DD
  budgetEstimate Float?
  status         String   @default("draft") // "draft" | "tendered" | "awarded" | "in_progress" | "complete"
  contractor     String?
  costEstimate   Float?
  currency       String   @default("GBP") // "GBP" | "USD"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset UserAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
}
